// Shared build settings for OctopusMenuBar

PRODUCT_NAME = OctopusMenuBar
PRODUCT_BUNDLE_IDENTIFIER = com.openoctopus.menubar
PRODUCT_DISPLAY_NAME = Open Octopus
PRODUCT_MODULE_NAME = OctopusMenuBar

MACOSX_DEPLOYMENT_TARGET = 14.0
SWIFT_VERSION = 6.0

GENERATE_INFOPLIST_FILE = YES
INFOPLIST_KEY_LSUIElement = YES
INFOPLIST_KEY_CFBundleDisplayName = $(PRODUCT_DISPLAY_NAME)
INFOPLIST_KEY_NSHumanReadableCopyright = Copyright © 2025 Open Octopus. All rights reserved.

ALWAYS_SEARCH_USER_PATHS = NO
ASSETCATALOG_COMPILER_APPICON_NAME = AppIcon
ASSETCATALOG_COMPILER_GLOBAL_ACCENT_COLOR_NAME = AccentColor

ENABLE_PREVIEWS = YES
SWIFT_EMIT_LOC_STRINGS = YES
